// Schema TENANT — criado dinamicamente por empresa
// Este schema é replicado para cada tenant_<uuid>

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_TENANT_URL") // sobrescrito em runtime por tenant
}

// ─── Filiais ─────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  name      String
  cnpj      String?
  address   String?
  city      String
  state     String   @db.Char(2)
  zipCode   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  vehicles   Vehicle[]
  drivers    Driver[]
  routes     Route[]
  checklists Checklist[]
}

// ─── Usuários & Roles ─────────────────────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  passwordHash     String
  role             UserRole
  branchId         String?
  branch           Branch?   @relation(fields: [branchId], references: [id])
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  refreshTokenHash String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  driver    Driver?
  auditLogs TenantAuditLog[]
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  DRIVER
  VIEWER
}

// ─── Veículos ─────────────────────────────────────────────────────────────────

model Vehicle {
  id                  String        @id @default(uuid())
  plate               String        @unique
  model               String
  brand               String
  year                Int
  type                VehicleType
  fuelType            FuelType
  status              VehicleStatus @default(ACTIVE)
  currentKm           Float         @default(0)
  nextMaintenanceKm   Float?
  nextMaintenanceDate DateTime?
  branchId            String
  branch              Branch        @relation(fields: [branchId], references: [id])
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  maintenanceRecords  MaintenanceRecord[]
  fuelRecords         FuelRecord[]
  routes              Route[]
  checklistExecutions ChecklistExecution[]
}

enum VehicleType {
  TRUCK
  VAN
  MOTORCYCLE
  CAR
  UTILITY
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum FuelType {
  GASOLINE
  ETHANOL
  DIESEL
  GNV
  ELECTRIC
  FLEX
}

// ─── Manutenção ───────────────────────────────────────────────────────────────

model MaintenanceRecord {
  id          String    @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  type        String // preventiva, corretiva, revisão
  description String
  cost        Decimal   @db.Decimal(10, 2)
  km          Float
  performedAt DateTime
  nextDueKm   Float?
  nextDueDate DateTime?
  provider    String
  notes       String?
  createdAt   DateTime  @default(now())
}

// ─── Abastecimento ────────────────────────────────────────────────────────────

model FuelRecord {
  id            String   @id @default(uuid())
  vehicleId     String
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
  driverId      String?
  driver        Driver?  @relation(fields: [driverId], references: [id])
  liters        Decimal  @db.Decimal(8, 3)
  pricePerLiter Decimal  @db.Decimal(8, 3)
  totalCost     Decimal  @db.Decimal(10, 2)
  km            Float
  fuelType      FuelType
  isFullTank    Boolean  @default(true)
  station       String?
  performedAt   DateTime
  createdAt     DateTime @default(now())
}

// ─── Motoristas ───────────────────────────────────────────────────────────────

model Driver {
  id              String          @id @default(uuid())
  userId          String?         @unique
  user            User?           @relation(fields: [userId], references: [id])
  name            String
  cpf             String          @unique
  phone           String
  licenseNumber   String          @unique
  licenseCategory LicenseCategory
  licenseExpiry   DateTime
  status          DriverStatus    @default(ACTIVE)
  branchId        String
  branch          Branch          @relation(fields: [branchId], references: [id])
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  documents           DriverDocument[]
  fuelRecords         FuelRecord[]
  routes              Route[]
  checklistExecutions ChecklistExecution[]
}

enum LicenseCategory {
  A
  B
  C
  D
  E
  AB
  AC
  AD
  AE
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_LEAVE
}

model DriverDocument {
  id          String    @id @default(uuid())
  driverId    String
  driver      Driver    @relation(fields: [driverId], references: [id])
  type        String
  description String
  fileUrl     String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

// ─── Rotas ────────────────────────────────────────────────────────────────────

model Route {
  id            String      @id @default(uuid())
  name          String
  vehicleId     String
  vehicle       Vehicle     @relation(fields: [vehicleId], references: [id])
  driverId      String
  driver        Driver      @relation(fields: [driverId], references: [id])
  branchId      String
  branch        Branch      @relation(fields: [branchId], references: [id])
  status        RouteStatus @default(DRAFT)
  scheduledDate DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  totalDistance Float?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  stops               RouteStop[]
  checklistExecutions ChecklistExecution[]
}

enum RouteStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── Paradas da Rota ──────────────────────────────────────────────────────────

model RouteStop {
  id                String             @id @default(uuid())
  routeId           String
  route             Route              @relation(fields: [routeId], references: [id])
  sequence          Int
  clientName        String
  clientDocument    String?
  address           String
  city              String
  state             String             @db.Char(2)
  zipCode           String?
  lat               Float?
  lng               Float?
  timeWindowStart   DateTime?
  timeWindowEnd     DateTime?
  status            StopStatus         @default(PENDING)
  nonDeliveryReason NonDeliveryReason?
  notes             String?
  arrivedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime           @default(now())

  items  DeliveryItem[]
  proofs DeliveryProof[]
}

enum StopStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  PARTIAL_DELIVERY
  NOT_DELIVERED
  RESCHEDULED
}

enum NonDeliveryReason {
  ABSENT_RECIPIENT
  REFUSED
  WRONG_ADDRESS
  DAMAGED_GOODS
  SECURITY
  OTHER
}

// ─── Itens de Entrega ─────────────────────────────────────────────────────────

model DeliveryItem {
  id                String    @id @default(uuid())
  stopId            String
  stop              RouteStop @relation(fields: [stopId], references: [id])
  description       String
  quantity          Int
  deliveredQuantity Int       @default(0)
  weight            Decimal?  @db.Decimal(8, 3)
  nfeNumber         String?
  barcode           String?
  createdAt         DateTime  @default(now())
}

// ─── Comprovante de Entrega ───────────────────────────────────────────────────

model DeliveryProof {
  id               String    @id @default(uuid())
  stopId           String
  stop             RouteStop @relation(fields: [stopId], references: [id])
  photoUrl         String?
  signatureUrl     String?
  lat              Float?
  lng              Float?
  receiverName     String?
  receiverDocument String?
  createdAt        DateTime  @default(now())
}

// ─── Checklists ───────────────────────────────────────────────────────────────

model Checklist {
  id        String        @id @default(uuid())
  name      String
  type      ChecklistType
  branchId  String?
  branch    Branch?       @relation(fields: [branchId], references: [id])
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())

  items      ChecklistItem[]
  executions ChecklistExecution[]
}

enum ChecklistType {
  PRE_TRIP
  POST_TRIP
  MAINTENANCE
}

model ChecklistItem {
  id          String    @id @default(uuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id])
  description String
  isRequired  Boolean   @default(true)
  order       Int
  allowPhoto  Boolean   @default(false)
  allowNotes  Boolean   @default(true)
  createdAt   DateTime  @default(now())

  responses ChecklistResponse[]
}

model ChecklistExecution {
  id          String    @id @default(uuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id])
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId    String
  driver      Driver    @relation(fields: [driverId], references: [id])
  routeId     String?
  route       Route?    @relation(fields: [routeId], references: [id])
  executedAt  DateTime  @default(now())
  hasIssues   Boolean   @default(false)

  responses ChecklistResponse[]
}

model ChecklistResponse {
  id          String              @id @default(uuid())
  executionId String
  execution   ChecklistExecution  @relation(fields: [executionId], references: [id])
  itemId      String
  item        ChecklistItem       @relation(fields: [itemId], references: [id])
  status      ChecklistItemStatus
  notes       String?
  photoUrl    String?
  createdAt   DateTime            @default(now())
}

enum ChecklistItemStatus {
  OK
  NOK
  NA
}

// ─── Auditoria por Tenant ─────────────────────────────────────────────────────

model TenantAuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}
